{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm fetch:downloads && pnpm check:docs && pnpm validate:snippets && pnpm build",
  "outputDirectory": "build",
  "framework": null,
  "redirects": [
    {
      "source": "/docs/api",
      "destination": "/docs/reference/api",
      "permanent": true
    },
    {
      "source": "/docs/api/:path*",
      "destination": "/docs/reference/api/:path*",
      "permanent": true
    }
  ]
}
